{
  "expo": {
    "name": "Twae",
    "slug": "twae",
    "scheme": "twae",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Twae-Logo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/Twae-Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Twae-Logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.db0sz.twae"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-system-ui",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dcaad50a-f172-4ab2-9db2-12678da43487"
      }
    }
  }
}
