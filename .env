# ═══════════════════════════════════════════════════════
# twae Frontend — Environment Configuration
# ═══════════════════════════════════════════════════════

# App Environment: "development" | "production"
EXPO_PUBLIC_APP_ENV=development

# API Base URL
# development: local backend
# production: deployed API
EXPO_PUBLIC_API_URL=http://localhost:8000/v1

# Feature Flags
EXPO_PUBLIC_ENABLE_BIOMETRIC=true
EXPO_PUBLIC_ENABLE_PLAID=true
EXPO_PUBLIC_ENABLE_FLUTTERWAVE=true
EXPO_PUBLIC_USE_MOCK=false

